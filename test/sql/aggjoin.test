# name: test/sql/aggjoin.test
# description: Test AggJoin optimizer (auto-fires on Aggregate(Join) patterns)
# group: [aggjoin]

require aggjoin

# Setup test data
statement ok
CREATE TABLE r (x INT, val DOUBLE);

statement ok
INSERT INTO r VALUES (1, 10.0), (2, 20.0), (3, 30.0);

statement ok
CREATE TABLE s (x INT, y INT);

statement ok
INSERT INTO s VALUES (1, 100), (1, 200), (2, 100), (2, 300);

statement ok
CREATE TABLE t (y INT, label TEXT);

statement ok
INSERT INTO t VALUES (100, 'A'), (200, 'B'), (300, 'C');

# ── Ungrouped aggregates ──

query I
SELECT CAST(SUM(r.val) AS INTEGER) FROM r JOIN s ON r.x = s.x;
----
60

query I
SELECT COUNT(*) FROM r JOIN s ON r.x = s.x;
----
4

query II
SELECT CAST(MIN(r.val) AS INTEGER), CAST(MAX(r.val) AS INTEGER)
FROM r JOIN s ON r.x = s.x;
----
10	20

query I
SELECT CAST(AVG(r.val) AS INTEGER) FROM r JOIN s ON r.x = s.x;
----
15

# No matches → COUNT returns 0
query I
SELECT COUNT(*) FROM r JOIN s ON r.x = s.x WHERE r.x = 99;
----
0

# ── NULL join keys (inner join excludes NULLs) ──

statement ok
CREATE TABLE r_null (x INT, val DOUBLE);

statement ok
INSERT INTO r_null VALUES (1, 10.0), (NULL, 99.0), (2, 20.0);

statement ok
CREATE TABLE s_null (x INT);

statement ok
INSERT INTO s_null VALUES (1), (NULL), (2);

query I
SELECT CAST(SUM(r_null.val) AS INTEGER) FROM r_null JOIN s_null ON r_null.x = s_null.x;
----
30

query I
SELECT COUNT(*) FROM r_null JOIN s_null ON r_null.x = s_null.x;
----
2

# ── Multiple groups sharing one join key ──
# GROUP BY grp produces 2 groups (A, B) for the same join key x=1.
# result_slot must be resolved per-row, not cached on BuildEntry.

statement ok
CREATE TABLE r2 (x INT, val DOUBLE);

statement ok
INSERT INTO r2 VALUES (1, 10.0), (1, 20.0);

statement ok
CREATE TABLE s2 (x INT, grp TEXT);

statement ok
INSERT INTO s2 VALUES (1, 'A'), (1, 'B');

query II rowsort
SELECT s2.grp, CAST(SUM(r2.val) AS INTEGER) FROM r2 JOIN s2 ON r2.x = s2.x GROUP BY s2.grp;
----
A	30
B	30

# ── Deterministic hash-collision tests ──
# Force all internal aggjoin hashes to 0 to verify exact key equality is used
# in build_ht and result_ht instead of raw hash_t identity.

query I
SELECT aggjoin_set_test_hash_bits(0);
----
0

statement ok
CREATE TABLE r_coll (x DOUBLE, val DOUBLE);

statement ok
INSERT INTO r_coll VALUES (1.5, 10.0), (2.5, 20.0);

statement ok
CREATE TABLE s_coll (x DOUBLE, grp INT);

statement ok
INSERT INTO s_coll VALUES (1.5, 100), (2.5, 200);

# Single-key DOUBLE join key exercises the surviving hash fallback.
# With all hashes forced equal, build_ht and result_ht must still keep rows apart.
query II rowsort
SELECT s_coll.grp, CAST(SUM(r_coll.val) AS INTEGER)
FROM r_coll JOIN s_coll ON r_coll.x = s_coll.x
GROUP BY s_coll.grp;
----
100	10
200	20

statement ok
CREATE TABLE r_comp (a INT, b INT, val DOUBLE);

statement ok
INSERT INTO r_comp VALUES (1, 10, 100.0), (2, 20, 200.0);

statement ok
CREATE TABLE s_comp (a INT, b INT, grp INT);

statement ok
INSERT INTO s_comp VALUES (1, 10, 1), (2, 20, 2);

# Composite keys exercise the BuildEntry.key_vals collision path.
query II rowsort
SELECT s_comp.grp, CAST(SUM(r_comp.val) AS INTEGER)
FROM r_comp JOIN s_comp ON r_comp.a = s_comp.a AND r_comp.b = s_comp.b
GROUP BY s_comp.grp;
----
1	100
2	200

query I
SELECT aggjoin_set_test_hash_bits(-1);
----
-1

# ── Multi-table join ──

query II rowsort
SELECT t.label, CAST(SUM(r.val) AS INTEGER)
FROM r JOIN s ON r.x = s.x JOIN t ON s.y = t.y
GROUP BY t.label;
----
A	30
B	10
C	20

# ============================================================
# Build-side aggregates: GROUP BY on probe, SUM/MIN/MAX on build
# After swap: s=probe, r=build. AGGJOIN accumulates r.val during Sink.
# ============================================================
statement ok
CREATE TABLE r_bs (x INT, val DOUBLE);

statement ok
INSERT INTO r_bs VALUES (1, 10.0), (1, 20.0), (2, 30.0);

statement ok
CREATE TABLE s_bs (x INT, y INT);

statement ok
INSERT INTO s_bs VALUES (1, 100), (1, 200), (2, 300);

# Build-side SUM: each probe row contributes build_sum[key]
# key 1: build_sum = 10+20 = 30. key 2: build_sum = 30.
# y=100 (key 1) → 30, y=200 (key 1) → 30, y=300 (key 2) → 30
query II rowsort
SELECT s_bs.y, CAST(SUM(r_bs.val) AS INTEGER) FROM r_bs JOIN s_bs ON r_bs.x = s_bs.x GROUP BY s_bs.y;
----
100	30
200	30
300	30

# Build-side MIN/MAX
query III rowsort
SELECT s_bs.y, CAST(MIN(r_bs.val) AS INTEGER), CAST(MAX(r_bs.val) AS INTEGER) FROM r_bs JOIN s_bs ON r_bs.x = s_bs.x GROUP BY s_bs.y;
----
100	10	20
200	10	20
300	30	30

# ── Non-numeric MIN/MAX: AGGJOIN bails, native handles correctly ──
# AGGJOIN bails on non-numeric MIN/MAX (VARCHAR, DATE) because the
# Value-based comparison path is 6-9x slower than native DuckDB.
# These tests verify native produces correct results (no crash).

statement ok
CREATE TABLE r_str (x INT, name VARCHAR);

statement ok
INSERT INTO r_str VALUES (1, 'charlie'), (2, 'alice'), (3, 'bob');

statement ok
CREATE TABLE s_str (x INT);

statement ok
INSERT INTO s_str VALUES (1), (2), (1);

# VARCHAR MIN/MAX (ungrouped) — handled by native
query II
SELECT MIN(r_str.name), MAX(r_str.name) FROM r_str JOIN s_str ON r_str.x = s_str.x;
----
alice	charlie

# VARCHAR MIN/MAX (grouped) — handled by native
query II rowsort
SELECT s_str.x, MIN(r_str.name) FROM r_str JOIN s_str ON r_str.x = s_str.x GROUP BY s_str.x;
----
1	charlie
2	alice

# Build-side VARCHAR MIN/MAX — no crash, native handles
statement ok
CREATE TABLE dim_str (id INT, label VARCHAR);

statement ok
INSERT INTO dim_str VALUES (1, 'zz_last'), (2, 'aa_first'), (3, 'mm_middle');

statement ok
CREATE TABLE fact_str (dim_id INT);

statement ok
INSERT INTO fact_str SELECT (i % 2) + 1 FROM generate_series(1, 100) t(i);

query II
SELECT MIN(dim_str.label), MAX(dim_str.label) FROM fact_str JOIN dim_str ON fact_str.dim_id = dim_str.id;
----
aa_first	zz_last

# Build-side mixed numeric + VARCHAR MIN/MAX
statement ok
CREATE TABLE dim_mix (id INT, val DOUBLE, label VARCHAR);

statement ok
INSERT INTO dim_mix VALUES
    (1, 10.0, 'zz_last'),
    (1, 20.0, 'aa_first'),
    (2, 30.0, 'mm_middle');

statement ok
CREATE TABLE fact_mix (dim_id INT, grp INT);

statement ok
INSERT INTO fact_mix VALUES
    (1, 100),
    (1, 200),
    (2, 300);

query IIII rowsort
SELECT fact_mix.grp, CAST(SUM(dim_mix.val) AS INTEGER), MIN(dim_mix.label), MAX(dim_mix.label)
FROM fact_mix JOIN dim_mix ON fact_mix.dim_id = dim_mix.id
GROUP BY fact_mix.grp;
----
100	30	aa_first	zz_last
200	30	aa_first	zz_last
300	30	mm_middle	mm_middle

# Build-side mixed numeric + DATE MIN/MAX (ungrouped)
statement ok
CREATE TABLE dim_mix_date (id INT, val DOUBLE, d DATE);

statement ok
INSERT INTO dim_mix_date VALUES
    (1, 10.0, '2020-01-15'),
    (1, 20.0, '2020-06-20'),
    (2, 30.0, '2021-03-10');

statement ok
CREATE TABLE fact_mix_date (dim_id INT);

statement ok
INSERT INTO fact_mix_date VALUES (1), (2), (1);

query III
SELECT CAST(SUM(dim_mix_date.val) AS INTEGER), MIN(dim_mix_date.d), MAX(dim_mix_date.d)
FROM fact_mix_date JOIN dim_mix_date ON fact_mix_date.dim_id = dim_mix_date.id;
----
90	2020-01-15	2021-03-10

# Mixed probe-side + build-side aggregates
statement ok
CREATE TABLE fact_side_mix (dim_id INT, grp INT, rv DOUBLE);

statement ok
INSERT INTO fact_side_mix VALUES
    (1, 100, 1.0),
    (1, 100, 2.0),
    (1, 200, 3.0),
    (2, 300, 4.0);

statement ok
CREATE TABLE dim_side_mix (id INT, sv DOUBLE, label VARCHAR);

statement ok
INSERT INTO dim_side_mix VALUES
    (1, 10.0, 'b_last'),
    (1, 20.0, 'a_first'),
    (2, 30.0, 'c_only');

query IIIII rowsort
SELECT fact_side_mix.grp,
       CAST(SUM(fact_side_mix.rv) AS INTEGER),
       CAST(SUM(dim_side_mix.sv) AS INTEGER),
       MIN(dim_side_mix.label),
       MAX(dim_side_mix.label)
FROM fact_side_mix
JOIN dim_side_mix ON fact_side_mix.dim_id = dim_side_mix.id
GROUP BY fact_side_mix.grp;
----
100	6	60	a_first	b_last
200	6	30	a_first	b_last
300	4	30	c_only	c_only

query IIII
SELECT CAST(SUM(fact_side_mix.rv) AS INTEGER),
       CAST(SUM(dim_side_mix.sv) AS INTEGER),
       MIN(dim_side_mix.label),
       MAX(dim_side_mix.label)
FROM fact_side_mix
JOIN dim_side_mix ON fact_side_mix.dim_id = dim_side_mix.id;
----
16	120	a_first	c_only

query IIIII rowsort
SELECT fact_side_mix.grp,
       CAST(AVG(fact_side_mix.rv) * 10 AS INTEGER),
       CAST(AVG(dim_side_mix.sv) AS INTEGER),
       MIN(dim_side_mix.label),
       MAX(dim_side_mix.label)
FROM fact_side_mix
JOIN dim_side_mix ON fact_side_mix.dim_id = dim_side_mix.id
GROUP BY fact_side_mix.grp;
----
100	15	15	a_first	b_last
200	30	15	a_first	b_last
300	40	30	c_only	c_only

# Composite-key mixed probe/build rewrite
statement ok
CREATE TABLE fact_comp_mix (k1 INT, k2 INT, rv DOUBLE);

statement ok
INSERT INTO fact_comp_mix VALUES
    (1, 10, 1.0),
    (1, 10, 3.0),
    (1, 20, 5.0),
    (2, 10, 7.0);

statement ok
CREATE TABLE dim_comp_mix (k1 INT, k2 INT, sv DOUBLE, d DATE);

statement ok
INSERT INTO dim_comp_mix VALUES
    (1, 10, 10.0, '2020-01-01'),
    (1, 10, 20.0, '2020-01-03'),
    (1, 20, 30.0, '2020-02-01'),
    (2, 10, 40.0, '2020-03-01');

query IIIIII rowsort
SELECT fact_comp_mix.k1,
       fact_comp_mix.k2,
       CAST(AVG(fact_comp_mix.rv) * 10 AS INTEGER),
       CAST(AVG(dim_comp_mix.sv) AS INTEGER),
       MIN(dim_comp_mix.d),
       MAX(dim_comp_mix.d)
FROM fact_comp_mix
JOIN dim_comp_mix
  ON fact_comp_mix.k1 = dim_comp_mix.k1
 AND fact_comp_mix.k2 = dim_comp_mix.k2
GROUP BY fact_comp_mix.k1, fact_comp_mix.k2;
----
1	10	20	15	2020-01-01	2020-01-03
1	20	50	30	2020-02-01	2020-02-01
2	10	70	40	2020-03-01	2020-03-01

# ── Narrow VARCHAR-key numeric path ──
# Single-key VARCHAR grouped/ungrouped SUM is now allowed on a narrow hash path.

statement ok
CREATE TABLE r_vkey (x VARCHAR, val DOUBLE);

statement ok
INSERT INTO r_vkey VALUES ('a', 10.0), ('a', 20.0), ('b', 30.0), ('c', 40.0);

statement ok
CREATE TABLE s_vkey (x VARCHAR);

statement ok
INSERT INTO s_vkey VALUES ('a'), ('a'), ('b'), ('c'), ('c');

query I
SELECT CAST(SUM(r_vkey.val) AS INTEGER) FROM r_vkey JOIN s_vkey ON r_vkey.x = s_vkey.x;
----
170

query II rowsort
SELECT r_vkey.x, CAST(SUM(r_vkey.val) AS INTEGER)
FROM r_vkey JOIN s_vkey ON r_vkey.x = s_vkey.x
GROUP BY r_vkey.x;
----
a	60
b	30
c	80

query II
SELECT CAST(MIN(r_vkey.val) AS INTEGER), CAST(MAX(r_vkey.val) AS INTEGER)
FROM r_vkey JOIN s_vkey ON r_vkey.x = s_vkey.x;
----
10	40

query III rowsort
SELECT r_vkey.x, CAST(MIN(r_vkey.val) AS INTEGER), CAST(MAX(r_vkey.val) AS INTEGER)
FROM r_vkey JOIN s_vkey ON r_vkey.x = s_vkey.x
GROUP BY r_vkey.x;
----
a	10	20
b	30	30
c	40	40

# DATE MIN/MAX — handled by native
statement ok
CREATE TABLE events (user_id INT, event_date DATE);

statement ok
INSERT INTO events VALUES (1, '2020-01-15'), (1, '2020-06-20'), (2, '2021-03-10');

statement ok
CREATE TABLE users (id INT);

statement ok
INSERT INTO users VALUES (1), (2);

query II
SELECT MIN(events.event_date), MAX(events.event_date) FROM events JOIN users ON events.user_id = users.id;
----
2020-01-15	2021-03-10

# Mixed: numeric SUM(DOUBLE) + VARCHAR MIN — bails to native (VARCHAR present)
statement ok
CREATE TABLE r_mix (x INT, val DOUBLE, name VARCHAR);

statement ok
INSERT INTO r_mix VALUES (1, 10.0, 'charlie'), (2, 20.0, 'alice');

statement ok
CREATE TABLE s_mix (x INT);

statement ok
INSERT INTO s_mix VALUES (1), (2), (1);

query III rowsort
SELECT s_mix.x, CAST(SUM(r_mix.val) AS INTEGER), MIN(r_mix.name) FROM r_mix JOIN s_mix ON r_mix.x = s_mix.x GROUP BY s_mix.x;
----
1	20	charlie
2	20	alice
