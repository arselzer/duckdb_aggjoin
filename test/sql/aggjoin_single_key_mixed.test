statement ok
CREATE TABLE dim_single_pure_nonnumeric (k INT, d DATE);

statement ok
INSERT INTO dim_single_pure_nonnumeric VALUES
    (1, '2021-01-01'),
    (1, '2021-01-03'),
    (2, '2021-02-01'),
    (3, '2021-03-01');

query IIIII rowsort
SELECT fact_single_pure_nonnumeric.k,
       MIN(fact_single_pure_nonnumeric.label),
       MAX(fact_single_pure_nonnumeric.label),
       MIN(dim_single_pure_nonnumeric.d),
       MAX(dim_single_pure_nonnumeric.d)
FROM fact_single_pure_nonnumeric
JOIN dim_single_pure_nonnumeric ON fact_single_pure_nonnumeric.k = dim_single_pure_nonnumeric.k
GROUP BY fact_single_pure_nonnumeric.k;
----
1	a_first	b_last	2021-01-01	2021-01-03
2	c_only	c_only	2021-02-01	2021-02-01
3	d_only	d_only	2021-03-01	2021-03-01

query IIII
SELECT MIN(fact_single_pure_nonnumeric.label),
       MAX(fact_single_pure_nonnumeric.label),
       MIN(dim_single_pure_nonnumeric.d),
       MAX(dim_single_pure_nonnumeric.d)
FROM fact_single_pure_nonnumeric
JOIN dim_single_pure_nonnumeric ON fact_single_pure_nonnumeric.k = dim_single_pure_nonnumeric.k;
----
a_first	d_only	2021-01-01	2021-03-01
