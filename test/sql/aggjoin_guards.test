statement ok
CREATE TABLE r_cap (x DOUBLE, val DOUBLE);

statement ok
INSERT INTO r_cap SELECT i::DOUBLE, 1.0 FROM generate_series(1, 20) t(i);

statement ok
CREATE TABLE s_cap (x DOUBLE, grp INT);

statement ok
INSERT INTO s_cap SELECT i::DOUBLE, i FROM generate_series(1, 20) t(i);

query I
SELECT aggjoin_set_test_ht_capacity(16);
----
16

statement error
SELECT s_cap.grp, CAST(SUM(r_cap.val) AS INTEGER)
FROM r_cap JOIN s_cap ON r_cap.x = s_cap.x
GROUP BY s_cap.grp;
----
capacity cap

query I
SELECT aggjoin_set_test_ht_capacity(-1);
----
-1

statement ok
CREATE TABLE dblp_path (fromNode INT, toNode INT);

statement ok
INSERT INTO dblp_path VALUES
  (1, 2),
  (1, 2),
  (2, 3),
  (2, 3),
  (3, 4),
  (4, 5);

query I
SELECT COUNT(*)
FROM dblp_path p1, dblp_path p2, dblp_path p3, dblp_path p4
WHERE p1.toNode = p2.fromNode
  AND p2.toNode = p3.fromNode
  AND p3.toNode = p4.fromNode;
----
4

query I
SELECT COUNT(*)
FROM dblp_path p1, dblp_path p2, dblp_path p3, dblp_path p4, dblp_path p5
WHERE p1.toNode = p2.fromNode
  AND p2.toNode = p3.fromNode
  AND p3.toNode = p4.fromNode
  AND p4.toNode = p5.fromNode;
----
0
